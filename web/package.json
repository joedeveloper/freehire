{
  "name": "freehire-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web frontend for the freehire job aggregator.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "og:smoke": "node scripts/og-smoke.mjs",
    "og:gen": "node scripts/gen-og.mjs",
    "gen:api-docs": "node scripts/gen-api-docs.mjs",
    "gen:api-docs:smoke": "node scripts/gen-api-docs-smoke.mjs",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.66.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "mdsvex": "^0.12.7",
    "oxlint": "^1.71.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.2",
    "svelte-eslint-parser": "^1.8.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.1",
    "tslib": "^2.6.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/sveltekit": "^10.63.0",
    "clsx": "^2.1.1",
    "easymde": "^2.21.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "svelte-dnd-action": "^0.9.70",
    "tailwind-merge": "^3.6.0"
