# --- Dev ---
# Backend the dev server proxies /api and /health to (keeps dev same-origin).
VITE_API_URL=http://localhost:8080

# --- Production (adapter-node server) ---
# Public origin of the site. REQUIRED in prod: behind nginx the Node server binds
# to a local port, so without this `url.origin` (used for canonical tags, og:url,
# JSON-LD urls and the sitemap <loc>s) would be an internal host. Alternatively set
# PROTOCOL_HEADER=x-forwarded-proto + HOST_HEADER=x-forwarded-host and have nginx
# forward them.
# ORIGIN=https://freehire.dev

# Internal origin the SSR server fetches the Go API from, server-to-server. A
# relative /api would hit this Node server, not the backend. Empty in dev (the
# Vite proxy handles it).
# API_INTERNAL_URL=http://app:8080
